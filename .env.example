# .env.example — SECRETS & API KEYS TEMPLATE
# Copy to .env and fill in your API keys. .env is gitignored.
# All other configuration lives in caratulai.config.yaml (see README).

# API Keys — one per model type (can be the same key or different services)
# For OpenRouter: https://openrouter.ai/keys
TEXT_MODEL_API_KEY=sk-or-v1-...
SVG_MODEL_API_KEY=sk-or-v1-...
IMAGE_MODEL_API_KEY=sk-or-v1-...
