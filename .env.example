# Copy to .env and fill in. .env is gitignored. See docs/providers.md.

# OpenRouter (remote) — one key, many models (Grok, Gemini, Llama, ...)
OPENROUTER_API_KEY=

# Optional: CLI defaults (set once, use for all generations)
# Available palettes: bw, grayscale, sepia, palette-16 (run `caratulai palettes` to list)
CARATULAI_PALETTE=sepia
# CARATULAI_TEMPERATURE=0.7

# Text extraction model (analyzes articles/narratives to extract concept tags)
CARATULAI_TEXT_PROVIDER=openrouter
CARATULAI_TEXT_MODEL=meta-llama/llama-3.2-3b-instruct

# SVG generation model (must be good at code generation; generates SVG from tags)
CARATULAI_SVG_PROVIDER=openrouter
CARATULAI_SVG_MODEL=meta-llama/llama-3.2-3b-instruct

# Image reading model (analyzes photos to extract visual concepts) [M6: Caratulize - future]
CARATULAI_IMAGE_PROVIDER=openrouter
CARATULAI_IMAGE_MODEL=gpt-4-vision

# Alternative: Use local Ollama instead of OpenRouter (free, no API costs)
# CARATULAI_TEXT_PROVIDER=ollama
# CARATULAI_TEXT_MODEL=llama3.2
# CARATULAI_SVG_PROVIDER=ollama
# CARATULAI_SVG_MODEL=qwen2.5-coder

# Optional: override local server locations (defaults shown)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
