# .env.example — SECRETS & API KEYS TEMPLATE
# Copy to .env and fill in your API keys. .env is gitignored.
#
# Configuration (models, tags, seed, ratio, etc.) lives in caratulai.config.yaml
# Keep this file for secrets only.

# OpenRouter API key (https://openrouter.ai/keys) — required for remote generation
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Local server URLs (if using Ollama or LM Studio instead of OpenRouter)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
