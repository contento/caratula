{
  "name": "@caratula/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "caratula command-line interface",
  "bin": {
    "caratula": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@caratula/core": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
